HF_TOKEN=your_huggingface_token_here
HF_MODEL=google/gemma-4-31B-it
DATASET_FILE=data/LifeChanger_Sample_Data_Populated_10000.csv
FRONTEND_ORIGIN=http://localhost:5173
PORT=5000

# F5-TTS (set to 0 for ImpactLens-only; model loads on first /api/tts/speak)
F5_TTS_ENABLED=1
# Leave unset for auto (cuda / mps / cpu). Do not set to an empty string.
# F5_TTS_DEVICE=cuda
F5_TTS_ODE_SOLVER_STEPS=32
F5_TTS_MODEL_NAME=F5TTS_v1_Base
F5_TTS_MODEL_CKPT=hf://SWivid/F5-TTS/F5TTS_v1_Base/model_1250000.safetensors
F5_TTS_OUTPUT_DIR=generated_audio

# LangChain optimization
LC_MEMORY_WINDOW=6
LC_USE_FAISS=0
